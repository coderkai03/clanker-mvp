# --- Gmail OAuth ---
# Path to the OAuth client secret JSON downloaded from Google Cloud Console
GMAIL_CREDENTIALS_PATH=credentials.json
# Token cache — created automatically after first OAuth flow
GMAIL_TOKEN_PATH=token.json

# --- Cron schedule ---
# How often (in hours) to poll for new emails (default: 1)
INGEST_INTERVAL_HOURS=1
# Max emails to fetch per ingest run (default: 20)
MAX_EMAILS_PER_RUN=20

# --- Logging ---
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
