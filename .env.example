# --- Gmail OAuth ---
# Path to the OAuth client secret JSON downloaded from Google Cloud Console
GMAIL_CREDENTIALS_PATH=credentials.json
# Token cache — created automatically after first OAuth flow
GMAIL_TOKEN_PATH=token.json

# --- Cron schedule ---
# How often (in hours) to poll for new emails (default: 1)
INGEST_INTERVAL_HOURS=1
# Max emails to fetch per ingest run (default: 20)
MAX_EMAILS_PER_RUN=20

# --- Logging ---
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# --- MCP transport / deployment ---
# stdio for local desktop clients (Claude Desktop/Cursor)
# streamable-http for hosted endpoints (e.g. Devin custom MCP via URL)
MCP_TRANSPORT=stdio
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_HTTP_PATH=/mcp
MCP_STATELESS_HTTP=true

# --- MongoDB Atlas (multi-session task store) ---
# Connection string from Atlas: mongodb+srv://<user>:<pass>@<cluster>/?retryWrites=true&w=majority
MONGODB_URI=
MONGODB_DB=clanker_mcp
MONGODB_TASKS_COLLECTION=tasks
# How long a worker holds a claim before it auto-releases (seconds)
CLAIM_LEASE_SECONDS=1800

# --- Anthropic AI (triage_inbox + validate_and_negotiate tools) ---
ANTHROPIC_API_KEY=
TRIAGE_MODEL=claude-haiku-4-5-20251001
NEGOTIATION_MODEL=claude-haiku-4-5-20251001

# --- Gmail push notifications (Pub/Sub webhook) ---
# Full topic name from GCP: projects/<gcp-project-id>/topics/<topic>
# Leave empty to disable webhook ingestion (cron polling still runs).
GMAIL_PUBSUB_TOPIC=
# Shared secret appended as ?token=... to your Pub/Sub push endpoint URL
GMAIL_WEBHOOK_TOKEN=
# Path the Pub/Sub push subscription POSTs to
GMAIL_WEBHOOK_PATH=/gmail/webhook
# How often to renew the Gmail watch (Gmail expires it after 7 days)
GMAIL_WATCH_RENEW_HOURS=24

# --- Dispatcher (Devin worker spawning, used by dispatcher.py) ---
DEVIN_API_KEY=
DEVIN_API_URL=https://api.devin.ai/v1
# Public URL of your MCP server, used in worker prompts so Devin knows where to call.
# Example: https://abc123.ngrok-free.app/mcp
MCP_PUBLIC_URL=
# How long a per-project worker lock lives without renewal (seconds)
WORKER_LEASE_SECONDS=1800
# How often the dispatcher reconciles missed change-stream events (seconds)
RECONCILE_INTERVAL_SECONDS=60
